{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*",

  "Fallen8": {
    "Durability": {
      "StorageDirectory": null,
      "CheckpointBaseName": "Temp.f8s",
      "WalPath": null,
      "Volatile": false,
      "SaveOnShutdown": true
    },
    "Security": {
      "ApiKey": null,
      "ApiKeyHeader": "X-Api-Key",
      "EnableDynamicCodeExecution": false,
      "EnableDynamicPluginLoading": false,
      "PluginDirectory": null,
      "AllowedCorsOrigins": [],
      "SensitiveRateLimitPermitPerWindow": 30,
      "RateLimitWindowSeconds": 10,
      "AllowRemoteAccess": false
    },
    "ChangeFeed": {
      "Enabled": true,
      "BufferSize": 8192,
      "SubscriberQueueSize": 1024,
      "MaxSubscribers": 32,
      "KeepAliveSeconds": 15
    },
    "BulkIO": {
      "ImportBatchSize": 10000,
      "MaxLineBytes": 1048576,
      "MaxImportRequestBytes": null
    },
    "Analytics": {
      "DefaultTimeBudgetSeconds": 30,
      "MaxTimeBudgetSeconds": 300,
      "MaxConcurrentRuns": 1
    },
    "Observability": {
      "Prometheus": {
        "Enabled": false,
        "RequireApiKey": false
      },
      "Otlp": {
        "Endpoint": null
      },
      "TracingSamplingRatio": 1.0,
      "StatisticsElementBudget": 1000000,
      "StatisticsTopN": 20
    }
  }
}
