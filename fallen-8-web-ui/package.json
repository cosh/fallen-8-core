{
  "name": "fallen-8-web-ui",
  "private": true,
  "version": "0.1.0",
  "description": "F8 Studio - browser frontend for Fallen-8 instances",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:apiapp": "tsc -b && vite build --outDir ../fallen-8-core-apiApp/wwwroot --emptyOutDir",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "gen:api": "openapi-typescript ../features/done/web-ui/openapi-v0.1.json -o src/api/openapi.d.ts"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-dialog": "^1.1.6",
    "@react-sigma/core": "^5.0.4",
    "@tanstack/react-query": "^5.66.0",
    "@tanstack/react-router": "^1.105.0",
    "graphology": "^0.26.0",
    "graphology-layout": "^0.6.1",
    "graphology-layout-forceatlas2": "^0.10.1",
    "monaco-editor": "^0.52.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sigma": "^3.0.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@tailwindcss/vite": "^4.0.6",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^5.0.0",
    "jsdom": "^26.0.0",
    "openapi-typescript": "^7.6.0",
    "tailwindcss": "^4.0.6",
    "typescript": "~5.9.0",
    "vite": "^7.0.0",
    "vitest": "^3.0.5"
  }
}
